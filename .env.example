# .env.example - Copy to .env and fill in your values
# NO SECRETS should be committed to git

# Choose your LLM model
# Option 1: Local model via Ollama
MODEL_TYPE=ollama
MODEL_NAME=mistral
# MODEL_NAME=neural-chat
# MODEL_NAME=llama2

# Option 2: Anthropic Claude (uncomment and add key)
# MODEL_TYPE=anthropic
# ANTHROPIC_API_KEY=your_key_here

# Option 3: Other OpenAI-compatible
# MODEL_TYPE=openai
# OPENAI_API_KEY=your_key_here
# OPENAI_MODEL_NAME=gpt-4-turbo

# Option 4: Groq
# MODEL_TYPE=groq
# GROQ_API_KEY=your_key_here
# MODEL_NAME=llama-3.1-8b-instant

# MCP Server settings
MCP_HOST=localhost
MCP_PORT=8000

# Crew settings
CREW_VERBOSE=true
CREW_MAX_ITER=10

# Paths
DATA_DIR=./data
OUTPUT_DIR=./outputs

# Logging
LOG_LEVEL=INFO
